# Server
PORT=4000
NODE_ENV=development

# Database (SQLite for dev, PostgreSQL connection string for prod)
# DATABASE_URL=postgresql://user:password@localhost:5432/hrcoc_finance

# JWT
JWT_SECRET=change-this-to-a-strong-random-secret-key
JWT_EXPIRES_IN=8h

# Plaid (Bank of America connectivity)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox

# After linking Bank of America via Plaid Link, store the access token here
BOA_ACCESS_TOKEN=

# Report output directory
REPORT_DIR=./reports
