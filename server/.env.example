# Server
PORT=4000
NODE_ENV=development

# Database
# Local dev: set DEV_DATABASE_URL to a local Postgres instance.
# Production: Railway injects DATABASE_URL automatically.
DEV_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stewardview
# DATABASE_URL=postgresql://user:password@localhost:5432/stewardview

# JWT
JWT_SECRET=change-this-to-a-strong-random-secret-key
JWT_EXPIRES_IN=8h

# Plaid — connects to any of 12,000+ banks and credit unions
# Sign up free at https://plaid.com to get your credentials
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox   # change to 'production' when ready

# Encryption key for Plaid access tokens stored at rest (AES-256-GCM).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PLAID_TOKEN_KEY=

# Your base organization display name (used in Plaid Link UI by default)
ORG_NAME=My Church Finance

# Report output directory
REPORT_DIR=./reports

# ── Multi-Tenant SaaS Config ─────────────────────────────
# Your deployed base URL. The React app lives under /app on this domain.
APP_URL=https://yourapp.com

# Only needed if your frontend is hosted on a different origin than the API.
# Example: https://app.yourapp.com,https://admin.yourapp.com
# CORS_ORIGINS=

# Platform super-admin secret (for X-Platform-Secret header or bootstrap admin creation)
PLATFORM_ADMIN_SECRET=change-this-to-a-very-strong-platform-secret

# Stripe — collect subscription payments from churches
# Sign up at https://stripe.com to get your keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — email delivery for MFA codes
# Sign up at https://resend.com to get your API key
RESEND_API_KEY=re_...
# EMAIL_FROM=StewardView <noreply@stewardview.com>
