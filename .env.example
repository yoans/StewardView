# ── Required for Railway ──────────────────────────────────
NODE_ENV=production
DATABASE_URL=              # Auto-set by Railway PostgreSQL plugin
JWT_SECRET=                # Generate a strong random secret
PORT=                      # Auto-set by Railway
APP_URL=                   # Public base URL, e.g. https://stewardview.com

# ── Optional ─────────────────────────────────────────────
JWT_EXPIRES_IN=8h
CORS_ORIGINS=              # Comma-separated only if frontend is on another origin
PLATFORM_ADMIN_SECRET=     # Needed for platform admin APIs if not using a platform-admin JWT

# ── Plaid bank connectivity ──────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
ORG_NAME=StewardView

# ── Stripe paid onboarding ───────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Report output directory ──────────────────────────────
REPORT_DIR=./reports
