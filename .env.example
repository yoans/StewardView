# ── Required for Railway ──────────────────────────────────
NODE_ENV=production
DATABASE_URL=              # Auto-set by Railway PostgreSQL plugin
JWT_SECRET=                # Generate a strong random secret
PORT=                      # Auto-set by Railway

# ── Optional ─────────────────────────────────────────────
JWT_EXPIRES_IN=8h

# ── Plaid (Bank of America connectivity) ─────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
BOA_ACCESS_TOKEN=

# ── Report output directory ──────────────────────────────
REPORT_DIR=./reports
